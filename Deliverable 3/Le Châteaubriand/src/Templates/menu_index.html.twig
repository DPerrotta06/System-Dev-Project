{% extends "layout.html.twig" %}
{% block title %}{{ trans('menu.main_course') }} – {{ trans('site.name') }}{% endblock %}
{% block content %}

<div class="admin-container">
    <aside class="admin-sidebar">
        <div class="admin-logo">{{ trans('admin.nav.logo') }}</div>
        <nav class="admin-nav">
            <a href="{{ base_path }}/admin">{{ trans('admin.dashboard.name') }}</a>
            <a href="{{ base_path }}/clients">{{ trans('admin.page.title') }}</a>
            <a href="{{ base_path }}/menus" class="active">{{ trans('menu.main_course') }}</a>
            <a href="{{ base_path }}/calendar">{{ trans('admin.nav.calendar') }}</a>
        </nav>
        <form action="{{ base_path }}/auth/logout" method="POST" style="margin-top:auto;">
            <button type="submit" class="admin-logout-btn">{{ trans('admin.nav.logout') }}</button>
        </form>
    </aside>

    <main class="admin-content">
        <div class="admin-page-header">
            <h2>{{ trans('menu.main_course') }}</h2>
        </div>

        {% for menu in menus %}
        <section class="admin-section">
            <div class="menu-header-row">
                <h3 class="admin-section-title">{{ menu.menuName }}</h3>
                <div class="menu-meta">
                    <span class="menu-price">${{ menu.pricePerPerson|number_format(2, '.', ',') }} {{ trans('menu.per_person') }}</span>
                    <a href="{{ base_path }}/menus/{{ menu.menuId }}/edit" class="admin-btn edit">{{ trans('client.edit') }}</a>
                </div>
            </div>

            {% set categories = {} %}
            {% for item in menu.items %}
                {% set cat = item.categoryName %}
                {% if categories[cat] is not defined %}
                    {% set categories = categories|merge({(cat): []}) %}
                {% endif %}
                {% set categories = categories|merge({(cat): categories[cat]|merge([item])}) %}
            {% endfor %}

            <div class="admin-table-wrapper">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>{{ trans('menu.category') }}</th>
                            <th>{{ trans('menu.item') }}</th>
                            <th>{{ trans('menu.extra_price') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in menu.items %}
                        <tr>
                            <td>{{ item.categoryName }}</td>
                            <td>{{ item.itemName }}</td>
                            <td>
                                {% if item.extraPrice and item.extraPrice > 0 %}
                                    +${{ item.extraPrice|number_format(2, '.', ',') }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="3" class="no-results">{{ trans('menu.no_items') }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
        {% else %}
        <p class="no-results">{{ trans('menu.no_menus') }}</p>
        {% endfor %}

    </main>
</div>

{% endblock %}
