{% extends "layout.html.twig" %}
{% block title %}{{ trans('admin.dashboard.name') }} – {{ trans('site.name') }}{% endblock %}
{% block content %}

<div class="admin-container">
    <aside class="admin-sidebar">
        <div class="admin-logo">{{ trans('admin.nav.logo') }}</div>

        <nav class="admin-nav">
            <a href="{{ base_path }}/admin"
            class="{% if active_page is defined and active_page == 'dashboard' %}active{% endif %}">
                {{ trans('admin.dashboard.name') }}
            </a>

            <a href="{{ base_path }}/clients"
            class="{% if active_page is defined and active_page == 'clients' %}active{% endif %}">
                {{ trans('admin.page.title') }}
            </a>

            <a href="{{ base_path }}/events"
            class="{% if active_page is defined and active_page == 'events' %}active{% endif %}">
                {{ trans('event.index_title') }}
            </a>

            <a href="{{ base_path }}/menus"
            class="{% if active_page is defined and active_page == 'menus' %}active{% endif %}">
                {{ trans('menu.main_course') }}
            </a>

            <a href="{{ base_path }}/calendar"
            class="{% if active_page is defined and active_page == 'calendar' %}active{% endif %}">
                {{ trans('admin.nav.calendar') }}
            </a>
        </nav>

        <form action="{{ base_path }}/auth/logout" method="POST" style="margin-top:auto;">
            <button type="submit" class="admin-logout-btn">
                {{ trans('admin.nav.logout') }}
            </button>
        </form>
    </aside>

    <main class="admin-content">
        <div class="admin-page-header">
            <h2>{{ trans('admin.dashboard.name') }}</h2>
        </div>

        <div class="admin-stats-bar">
            <div class="stat-card">
                <span class="stat-number">{{ stats.pending }}</span>
                <span class="stat-label">{{ trans('admin.stats.pending') }}</span>
            </div>
            <div class="stat-card confirmed">
                <span class="stat-number">{{ stats.confirmedMonth }}</span>
                <span class="stat-label">{{ trans('admin.stats.confirmed_month') }}</span>
            </div>
            <div class="stat-card">
                <span class="stat-number">{{ stats.totalClients }}</span>
                <span class="stat-label">{{ trans('admin.stats.total_clients') }}</span>
            </div>
            <div class="stat-card">
                <span class="stat-number">{{ stats.totalEvents }}</span>
                <span class="stat-label">{{ trans('admin.stats.total_events') }}</span>
            </div>
        </div>

        <section class="admin-section">
            <h3 class="admin-section-title">{{ trans('admin.sections.pending') }}</h3>
            <div class="admin-table-wrapper">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>{{ trans('admin.table.client') }}</th>
                            <th>{{ trans('admin.table.event_type') }}</th>
                            <th>{{ trans('admin.table.date') }}</th>
                            <th>{{ trans('admin.table.guests') }}</th>
                            <th>{{ trans('admin.table.budget') }}</th>
                            <th>{{ trans('admin.table.status') }}</th>
                            <th>{{ trans('admin.table.actions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for event in pending %}
                        <tr>
                            <td>{{ event.clientName }}</td>
                            <td>{{ event.eventType }}</td>
                            <td>{{ event.eventDate }}</td>
                            <td>{{ event.guestCount }}</td>
                            <td>${{ event.totalPrice ? event.totalPrice|number_format(0, '.', ',') : '—' }}</td>
                            <td><span class="status-badge pending">{{ trans('status.pending') }}</span></td>
                            <td>
                                <a href="{{ base_path }}/clients/{{ event.clientId }}" class="admin-btn edit">{{ trans('admin.actions.view_details') }}</a>
                                <form action="{{ base_path }}/events/{{ event.eventId }}/status" method="POST" style="display:inline;">
                                    <input type="hidden" name="status" value="Confirmed">
                                    <button type="submit" class="admin-btn confirm-btn">{{ trans('admin.actions.confirm') }}</button>
                                </form>
                                <form action="{{ base_path }}/events/{{ event.eventId }}/status" method="POST" style="display:inline;">
                                    <input type="hidden" name="status" value="Cancelled">
                                    <button type="submit" class="admin-btn delete">{{ trans('admin.actions.cancel') }}</button>
                                </form>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="no-results">{{ trans('admin.states.no_pending') }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

        <section class="admin-section">
            <h3 class="admin-section-title">{{ trans('admin.sections.upcoming') }}</h3>
            <div class="admin-table-wrapper">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>{{ trans('admin.table.client') }}</th>
                            <th>{{ trans('admin.table.event_type') }}</th>
                            <th>{{ trans('admin.table.date') }}</th>
                            <th>{{ trans('admin.table.time') }}</th>
                            <th>{{ trans('admin.table.guests') }}</th>
                            <th>{{ trans('admin.table.ballroom') }}</th>
                            <th>{{ trans('admin.table.details') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for event in upcoming %}
                        <tr>
                            <td>{{ event.clientName }}</td>
                            <td>{{ event.eventType }}</td>
                            <td>{{ event.eventDate }}</td>
                            <td>{{ event.eventTime }}</td>
                            <td>{{ event.guestCount }}</td>
                            <td>{{ event.ballroom ?? '—' }}</td>
                            <td><a href="{{ base_path }}/events/{{ event.eventId }}" class="admin-btn edit">{{ trans('admin.actions.view_details') }}</a></td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="no-results">{{ trans('admin.states.no_upcoming') }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>

    </main>
</div>

{% endblock %}
