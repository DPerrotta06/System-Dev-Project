{% extends "layout.html.twig" %}
{% block title %}Admin Dashboard – Le Châteaubriand{% endblock %}
{% block content %}

<div class="admin-container">
    <aside class="admin-sidebar">
        <div class="admin-logo">Le Châteaubriand</div>
        <nav class="admin-nav">
            <a href="{{ base_path }}/clients" class="active">Clients</a>
            <a href="{{ base_path }}/menus">Menus</a>
            <a href="{{ base_path }}/calendar">Calendar</a>
        </nav>
        <form action="{{ base_path }}/auth/logout" method="POST" style="margin-top:auto;">
            <button type="submit" class="admin-logout-btn">Logout</button>
        </form>
    </aside>

    <main class="admin-content">
        <div class="admin-page-header">
            <h2>Client Management</h2>
            <h3>All registered clients</h3>
        </div>

        <div class="admin-controls">
            <input type="text" class="admin-search" placeholder="Search clients...">
            <button class="admin-filter-btn">Filter</button>
        </div>

        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Client Name</th>
                        <th>Email</th>
                        <th>Tel.</th>
                        <th>Event Type</th>
                        <th>Date</th>
                        <th>Number of Guests</th>
                        <th>Budget</th>
                        <th>Status</th>
                        <th>Details</th>
                        <th>Remove Client</th>
                    </tr>
                </thead>
                <tbody>
                    {% for client in clients %}
                    <tr>
    <td>{{ client.clientName }}</td>
    <td>{{ client.clientEmail }}</td>
    <td>{{ client.phone }}</td>
    <td>{{ client.eventType }}</td>
    <td>{{ client.eventDate }}</td>
    <td>{{ client.guestCount }}</td>
    <td>${{ client.totalPrice|number_format(0, '.', ',') }}</td>
    <td><span class="status-badge {{ client.status|lower }}">{{ client.status|capitalize }}</span></td>
    <td><a href="{{ base_path }}/clients/{{ client.clientId }}" class="admin-btn edit">View</a></td>
    <td>
        <form action="{{ base_path }}/clients/{{ client.clientId }}/delete" method="POST" style="display:inline;">
            <button type="submit" class="admin-btn delete">Delete</button>
        </form>
    </td>
</tr>
{% else %}
<tr>
    <td colspan="10" class="no-results">No clients found.</td>
</tr>
{% endfor %}
                </tbody>
            </table>
        </div>
    </main>
</div>

{% endblock %}
