{% extends "layout.html.twig" %}
{% block title %}{{ trans('admin.dashboard.name') }} – {{ trans('site.name') }}{% endblock %}
{% block content %}

<div class="admin-container">
    <aside class="admin-sidebar">
        <div class="admin-logo">{{ trans('admin.nav.logo') }}</div>
        <nav class="admin-nav">
            <a href="{{ base_path }}/clients" class="active">{{ trans('admin.page.title') }}</a>
            <a href="{{ base_path }}/menus">{{ trans('menu.main_course') }}</a>
            <a href="{{ base_path }}/calendar">{{ trans('admin.nav.calendar') }}</a>
        </nav>
        <form action="{{ base_path }}/auth/logout" method="POST" style="margin-top:auto;">
            <button type="submit" class="admin-logout-btn">{{ trans('admin.nav.logout') }}</button>
        </form>
    </aside>

    <main class="admin-content">
        <div class="admin-page-header">
            <h2>{{ trans('admin.page.title') }}</h2>
            <h3>{{ trans('admin.dashboard.name') }}</h3>
        </div>

        <div class="admin-controls">
            <input type="text" class="admin-search" placeholder="{{ trans('admin.controls.search_placeholder') }}">
            <button class="admin-filter-btn">{{ trans('admin.controls.filter') }}</button>
        </div>

        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>{{ trans('admin.table.phone') }}</th>
                        <th>{{ trans('admin.table.event_type') }}</th>
                        <th>{{ trans('admin.table.date') }}</th>
                        <th>{{ trans('admin.table.guests') }}</th>
                        <th>{{ trans('admin.table.budget') }}</th>
                        <th>{{ trans('admin.table.status') }}</th>
                        <th>{{ trans('admin.table.details') }}</th>
                        <th>{{ trans('admin.table.delete') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for client in clients %}
                    <tr>
                        <td>{{ client.phone }}</td>
                        <td>{{ client.eventType }}</td>
                        <td>{{ client.eventDate }}</td>
                        <td>{{ client.guestCount }}</td>
                        <td>${{ client.totalPrice|number_format(0, '.', ',') }}</td>
                        <td><span class="status-badge {{ client.status|lower }}">{{ trans('status.' ~ client.status|lower) }}</span></td>
                        <td><a href="{{ base_path }}/clients/{{ client.clientId }}" class="admin-btn edit">{{ trans('admin.actions.view_details') }}</a></td>
                        <td>
                            <form action="{{ base_path }}/clients/{{ client.clientId }}/delete" method="POST" style="display:inline;">
                                <button type="submit" class="admin-btn delete">{{ trans('admin.actions.delete_client') }}</button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="8" class="no-results">{{ trans('admin.states.no_clients') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </main>
</div>

{% endblock %}