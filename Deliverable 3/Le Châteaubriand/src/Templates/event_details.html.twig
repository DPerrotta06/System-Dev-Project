{% extends "layout.html.twig" %}

{% block title %}
    {{ trans('site.name') }} – {{ event.eventType }} – {{ event.eventDate }}
{% endblock %}

{% block content %}
<div class="admin-container">
    <aside class="admin-sidebar">
        <div class="admin-logo">{{ trans('admin.nav.logo') }}</div>

        <nav class="admin-nav">
            <a href="{{ base_path }}/admin">{{ trans('admin.dashboard.name') }}</a>
            <a href="{{ base_path }}/clients">{{ trans('admin.page.title') }}</a>
            <a href="{{ base_path }}/events" class="active">Events</a>
            <a href="{{ base_path }}/menus">{{ trans('menu.main_course') }}</a>
            <a href="{{ base_path }}/calendar">{{ trans('admin.nav.calendar') }}</a>
        </nav>

        <form action="{{ base_path }}/auth/logout" method="POST" style="margin-top:auto;">
            <button type="submit" class="admin-logout-btn">{{ trans('admin.nav.logout') }}</button>
        </form>
    </aside>

    <main class="admin-content event-details-page">

        <div class="admin-page-header event-details-header">
            <div>
                <a href="{{ base_path }}/events" class="admin-btn back-btn">← Back</a>
                <h2>Event Details</h2>
                <p class="page-subtitle">
                    {{ event.eventType }} for {{ event.clientName }}
                </p>
            </div>
        </div>

        <section class="event-hero-card">
            <div>
                <span class="status-badge {{ event.status|lower }}">
                    {{ event.status }}
                </span>

                <h1>{{ event.eventType }}</h1>

                <div class="event-meta-list">
                    <span>{{ event.eventDate }}</span>
                    <span>{{ event.eventTime }}</span>
                    <span>{{ event.guestCount }} guests</span>
                    <span>{{ event.ballroom ?? 'No ballroom assigned' }}</span>
                </div>
            </div>

            <div class="event-status-actions">
                {% for s in ['Confirmed','Cancelled','Completed','Declined'] %}
                    {% if event.status != s %}
                        <form action="{{ base_path }}/events/{{ event.eventId }}/status" method="POST">
                            <input type="hidden" name="status" value="{{ s }}">
                            <button type="submit" class="admin-btn {{ s == 'Confirmed' ? 'confirm-btn' : 'delete' }}">
                                {{ s }}
                            </button>
                        </form>
                    {% endif %}
                {% endfor %}
            </div>
        </section>

        <div class="details-layout">

            <section class="detail-card">
                <div class="detail-card-header">
                    <h3>Event Information</h3>
                </div>

                <div class="detail-grid">
                    <div class="detail-row">
                        <span class="detail-label">Date</span>
                        <span class="detail-value">{{ event.eventDate }}</span>
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">Time</span>
                        <span class="detail-value">{{ event.eventTime }}</span>
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">Guests</span>
                        <span class="detail-value">{{ event.guestCount }}</span>
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">Ballroom</span>
                        <span class="detail-value">{{ event.ballroom ?? '—' }}</span>
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">Menu</span>
                        <span class="detail-value">{{ event.menuName ?? '—' }}</span>
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">Bar</span>
                        <span class="detail-value">
                            {% if event.barType %}
                                {{ event.barType }} · {{ event.barOpen }} – {{ event.barClose }} · ${{ event.barPricePerPerson }}/person
                            {% else %}
                                —
                            {% endif %}
                        </span>
                    </div>

                    {% if event.description %}
                        <div class="detail-row full-width">
                            <span class="detail-label">Description</span>
                            <span class="detail-value">{{ event.description }}</span>
                        </div>
                    {% endif %}
                </div>
            </section>

            <section class="detail-card">
                <div class="detail-card-header">
                    <h3>Client</h3>
                </div>

                <div class="client-summary-card">
                    <div class="client-avatar">
                        {{ event.clientName|slice(0, 1)|upper }}
                    </div>

                    <div>
                        <div class="client-name">{{ event.clientName }}</div>
                        <p>{{ event.clientEmail }}</p>
                        <p>{{ event.clientPhone }}</p>
                    </div>
                </div>
            </section>

            {% if event.totalPrice %}
                <section class="detail-card payment-card">
                    <div class="detail-card-header">
                        <h3>Payment</h3>
                    </div>

                    <div class="payment-summary">
                        <div>
                            <span class="payment-label">Total</span>
                            <strong>${{ event.totalPrice|number_format(2, '.', ',') }}</strong>
                        </div>

                        <div>
                            <span class="payment-label">Paid</span>
                            <strong>${{ event.amountPaid|number_format(2, '.', ',') }}</strong>
                        </div>

                        <div>
                            <span class="payment-label">Balance</span>
                            <strong>${{ event.amountLeft|number_format(2, '.', ',') }}</strong>
                        </div>
                    </div>

                    <div class="detail-grid payment-details">
                        <div class="detail-row">
                            <span class="detail-label">Deposit</span>
                            <span class="detail-value">${{ event.depositRequired|number_format(2, '.', ',') }}</span>
                        </div>

                        <div class="detail-row">
                            <span class="detail-label">Plan</span>
                            <span class="detail-value">{{ event.paymentPlan }}</span>
                        </div>

                        <div class="detail-row">
                            <span class="detail-label">Method</span>
                            <span class="detail-value">{{ event.paymentMethod }}</span>
                        </div>

                        {% if event.nextPaymentDue %}
                            <div class="detail-row">
                                <span class="detail-label">Next Due</span>
                                <span class="detail-value">{{ event.nextPaymentDue }}</span>
                            </div>
                        {% endif %}
                    </div>
                </section>
            {% endif %}

        </div>

        {% if services is defined and services|length > 0 %}
            <section class="admin-section services-section">
                <div class="detail-card-header">
                    <h3>Services</h3>
                </div>

                <div class="admin-table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Service Name</th>
                                <th>Type</th>
                                <th>Email</th>
                                <th>Phone</th>
                            </tr>
                        </thead>

                        <tbody>
                            {% for s in services %}
                                <tr>
                                    <td>{{ s.serviceName }}</td>
                                    <td>{{ s.serviceType }}</td>
                                    <td>{{ s.serviceEmail }}</td>
                                    <td>{{ s.servicePhone }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        {% endif %}

    </main>
</div>
{% endblock %}