{% extends "layout.html.twig" %}

{% block title %}
	{{ 'admin.dashboard.name'|trans }} – {{ 'site.name'|trans }}
{% endblock %}

{% block content %}

	<div class="admin-container">

		<div class="admin-top-nav">

			<div class="admin-logo">
				{{ 'admin.nav.logo'|trans }}
			</div>

			<div class="admin-nav-links">

				<a href="{{ base_path }}/calendar">
					{{ 'admin.nav.calendar'|trans }}
				</a>

				<a href="{{ base_path }}/logout">
					{{ 'admin.nav.logout'|trans }}
				</a>

				<div class="admin-user">
					<span>{{ user.email }}</span>
				</div>

			</div>

		</div>

		<h1 class="admin-page-title">
			{{ 'admin.page.title'|trans }}
		</h1>

		<div class="admin-controls">

			<input type="text" class="admin-search" placeholder="{{ 'admin.controls.search_placeholder'|trans }}">

			<button class="admin-filter-btn">
				{{ 'admin.controls.filter'|trans }}
			</button>

		</div>

		<div class="admin-table-wrapper">

			<table class="admin-table">

				<thead>

					<tr>
						<th>{{ 'admin.table.phone'|trans }}</th>
						<th>{{ 'admin.table.event_type'|trans }}</th>
						<th>{{ 'admin.table.date'|trans }}</th>
						<th>{{ 'admin.table.guests'|trans }}</th>
						<th>{{ 'admin.table.budget'|trans }}</th>
						<th>{{ 'admin.table.status'|trans }}</th>
						<th>{{ 'admin.table.details'|trans }}</th>
						<th>{{ 'admin.table.delete'|trans }}</th>
					</tr>

				</thead>

				<tbody>

					{% for client in clients %}

						<tr>

							<td>
								{{ client.phone }}
							</td>

							<td>
								{{ client.event_type }}
							</td>

							<td>
								{{ client.date }}
							</td>

							<td>
								{{ client.guests }}
							</td>

							<td>
								${{ client.budget|number_format(0, '.', ',') }}
							</td>

							<td class="status {{ client.status|lower }}">
								{{ ('status.' ~ client.status|lower)|trans }}
							</td>

							<td>

								<a href="{{ base_path }}/admin/client/{{ client.id }}" class="details-link">
									{{ 'admin.actions.view_details'|trans }}
								</a>

							</td>

							<td>

								<a href="{{ base_path }}/admin/client/{{ client.id }}" class="delete-link">
									{{ 'admin.actions.delete_client'|trans }}
								</a>

							</td>

						</tr>

					{% else %}

						<tr>

							<td colspan="8" class="no-results">
								{{ 'admin.states.no_clients'|trans }}
							</td>

						</tr>

					{% endfor %}

				</tbody>

			</table>

		</div>

	</div>

{% endblock %}
