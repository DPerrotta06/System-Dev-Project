{% extends 'layout.html.twig' %}
{% block title %}Le Châteaubriand{% endblock %}
{% block content %}
<h4>Make your event yours!</h4>
<p>Select the tables for your event and specify the number of guests per table (Maximum: 12)</p>
<div class="floor-planning-container">
    <p>
        Your Ballroom:
        <strong>
            {% if hall == 'royal' %}Royal hall
            {% elseif hall == 'grand_salon' %}Grand Salon
            {% else %}Princess
            {% endif %}
        </strong>
    </p>
    <div class="floor-planning-summary">
        <p id="tableCount">{{ table_quantity }} Tables</p>
        <p id="guestCount">{{ guest_quantity }} Guests</p>
    </div
    <div class="floor-planning-ui">
        <canvas id="floor-canvas" width="800" height="600"></canvas>
    </div>
    <div class="table-selection-grid-container">
        {% for i in 1..26 %}
        <div class="table-card">
            <div class="table-card-header">
                <span>Table {{ i }}</span>
                <input type="checkbox" class="table-card-checkbox">
            </div>
            <div class="card-body">
                <small>Click to select the table</small>
                <input type="number" class="table-card-guest-input" min="1" max="12" disabled>
            </div>
        </div>
        {%endfor%}
    </div>
</div>
