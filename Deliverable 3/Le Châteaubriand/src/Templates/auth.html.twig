{% extends "layout.html.twig" %}

{% block title %}
	{{ 'site.name'|trans }}
{% endblock %}

{% block content %}

	<div class="login-form-container">

		{% if step == 'login' %}

			<div class="login-card">

				<div style="font-size: 36px; margin-bottom: 10px;"></div>

				<h2>{{ 'site.name'|trans }}</h2>

				<h3>{{ 'auth.title'|trans }}</h3>

				<form action="{{ base_path }}/auth/2fa" method="post">

					<div class="form-group">

						<label>
							{{ 'auth.email'|trans }}
						</label>

						<div class="input-wrapper">
							<input type="email" name="_username" autocomplete="_username" placeholder="{{ 'auth.email_placeholder'|trans }}" required>
						</div>

					</div>

					<div class="form-group">

						<label>
							{{ 'auth.password'|trans }}
						</label>

						<div class="input-wrapper">
							<input type="password" name="_password" placeholder="{{ 'auth.password_placeholder'|trans }}" required>
						</div>

					</div>

					<button type="submit" class="login-btn">
						{{ 'auth.login'|trans }}
					</button>

				</form>

			</div>

		</div>

	{% elseif step == 'otp_display' %}

		<div class="twofa-container">

			<div class="twofa-card">

				<h2>{{ 'auth.otp_sent'|trans }}</h2>

				<img src="{{ qr_code }}" alt="TOTP QR code" style="display:block;margin:1rem auto;width:200px;height:200px;">

				<p class="otp-note">
					{{ 'auth.otp_note'|trans }}
				</p>

				<a href="{{ base_path }}/auth/verify" class="btn btn-primary">
					{{ 'auth.continue'|trans }}
				</a>

			</div>

		</div>

	{% elseif step == 'verify' %}

		<div class="card auth-card">

			<h2>
				{{ 'auth.verify_title'|trans }}
			</h2>

			{% if error is defined %}
				<p class="auth-error">
					{{ error|trans }}
				</p>
			{% endif %}

			<form class="auth-form" action="{{ base_path }}/auth/verify" method="POST">

				<label for="code">
					{{ 'auth.otp_label'|trans }}
				</label>

				<input type="text" id="code" name="code" placeholder="{{ 'auth.otp_placeholder'|trans }}" maxlength="6" inputmode="numeric" autocomplete="one-time-code" required>

				<button type="submit" class="btn btn-primary">
					{{ 'auth.verify'|trans }}
				</button>

			</form>

		</div>

	{% endif %}

{% endblock %}
