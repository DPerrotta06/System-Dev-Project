{% extends "layout.html.twig" %}
{% block title %}{{ trans('site.name') }}{% endblock %}
{% block content %}

<div class="login-form-container">

    {% if step == 'login' %}
    <div class="login-card">
        <h2>{{ trans('site.name') }}</h2>
        <h3>{{ trans('auth.title') }}</h3>

        <form action="{{ base_path }}/auth/request" method="POST">
            <div class="form-group">
                <label>{{ trans('auth.email') }}</label>
                <div class="input-wrapper">
                    <input type="email" name="username" placeholder="{{ trans('auth.email_placeholder') }}" autocomplete="username" required>
                </div>
            </div>

            <div class="form-group">
                <label>{{ trans('auth.password') }}</label>
                <div class="input-wrapper">
                    <input type="password" name="password" placeholder="{{ trans('auth.password_placeholder') }}" required>
                </div>
            </div>

            <button type="submit" class="login-btn">{{ trans('auth.login') }}</button>
        </form>
    </div>

    {% elseif step == 'otp_display' %}
    <div class="twofa-container">
        <div class="twofa-card">
            <h2>{{ trans('auth.otp_sent') }}</h2>
            <img src="{{ qr_code }}" alt="TOTP QR code">
            <p class="otp-note">{{ trans('auth.otp_note') }}</p>
            <a href="{{ base_path }}/auth/verify" class="btn btn-primary">{{ trans('auth.continue') }}</a>
        </div>
    </div>

    {% elseif step == 'verify' %}
    <div class="login-form-container">
        <div class="auth-card">
            <h2>{{ trans('auth.verify_title') }}</h2>

            {% if error is defined %}
                <p class="auth-error">{{ trans(error) }}</p>
            {% endif %}

            <form class="auth-form" action="{{ base_path }}/auth/verify" method="POST">
                <label for="code">{{ trans('auth.otp_label') }}</label>
                <input
                    type="text"
                    id="code"
                    name="code"
                    placeholder="{{ trans('auth.otp_placeholder') }}"
                    maxlength="6"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    required
                >
                <button type="submit" class="btn btn-primary">{{ trans('auth.verify') }}</button>
            </form>
        </div>
    </div>

    {% endif %}

</div>
{% endblock %}