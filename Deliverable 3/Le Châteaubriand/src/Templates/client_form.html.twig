{% extends 'layout.html.twig' %}
{% block title %}Le Châteaubriand{% endblock %}
{% block content %}
<div class="client-form-container">

    <form action="{{ base_path }}/table_plan" method="post">

        <h3>Personal Information</h3>
        <input type="text" name="firstname" placeholder="First Name" required>
        <input type="text" name="lastname" placeholder="Last Name" required>
        <input type="email" name="email" placeholder="Email" required>
        <input type="text" name="phone" placeholder="Phone" required>

        <h3>Event Details</h3>
        <select name="event_type" required>
            <option value="">Select an Event Type</option>
            <option value="Wedding">Wedding</option>
            <option value="Corporate">Corporate Event</option>
            <option value="Birthday">Birthday Party</option>
            <option value="Anniversary">Anniversary</option>
            <option value="Baby Shower">Baby Shower</option>
            <option value="Other">Other</option>
        </select>
            <div class="date-wrapper">
                <input type="date" name="event_date" id="event_date" required>
                <span class="date-placeholder">Date of your event</span>
            </div>        
        <input type="number" name="number_of_guests" placeholder="Number of guests" min="1" required>

        <h3>Menu Selection</h3>
        <label><input type="checkbox" class="menu-toggle" data-target="mainMenu"> Main Menu</label>
        <label><input type="checkbox" class="menu-toggle" data-target="buffetMenu"> Buffet</label>
        <label><input type="checkbox" class="menu-toggle" data-target="midnightMenu"> Midnight Table</label>

        <div id="mainMenu" class="menu-section hidden">
            {% for key, items in menus.main %}
                <div class="menu-category">
                    <h4>{{ key|replace({'_': ' '})|title }}</h4>
                    {% for item in items %}
                        <label>
                            <input type="checkbox" name="main_{{ key }}[]" value="{{ item }}">
                            {{ item }}
                        </label>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>

        <div id="buffetMenu" class="menu-section hidden">
            {% for key, items in menus.buffet %}
                <div class="menu-category">
                    <h4>{{ key|replace({'_': ' '})|title }}</h4>
                    {% for item in items %}
                        <label>
                            <input type="checkbox" name="buffet_{{ key }}[]" value="{{ item }}">
                            {{ item }}
                        </label>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>

        <div id="midnightMenu" class="menu-section hidden">
            {% for key, items in menus.midnight %}
                <div class="menu-category">
                    <h4>{{ key|replace({'_': ' '})|title }}</h4>
                    {% for item in items %}
                        <label>
                            <input type="checkbox" name="midnight_{{ key }}[]" value="{{ item }}">
                            {{ item }}
                        </label>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>

        <h3>Additional Notes</h3>
        <textarea name="notes" placeholder="Special requests, allergies, etc."></textarea>
        <br><br>
        <button type="submit">Continue to floor planning</button>

    </form>
</div>
{% endblock %}