{% extends "layout.html.twig" %}
{% block title %}{{ trans('admin.page.title') }} – {{ trans('site.name') }}{% endblock %}
{% block content %}

<div class="admin-container">
    <aside class="admin-sidebar">
        <div class="admin-logo">{{ trans('admin.nav.logo') }}</div>

        <nav class="admin-nav">
            <a href="{{ base_path }}/admin"
            class="{% if active_page is defined and active_page == 'dashboard' %}active{% endif %}">
                {{ trans('admin.dashboard.name') }}
            </a>

            <a href="{{ base_path }}/clients"
            class="{% if active_page is defined and active_page == 'clients' %}active{% endif %}">
                {{ trans('admin.page.title') }}
            </a>

            <a href="{{ base_path }}/events"
            class="{% if active_page is defined and active_page == 'events' %}active{% endif %}">
                {{ trans('event.index_title') }}
            </a>

            <a href="{{ base_path }}/menus"
            class="{% if active_page is defined and active_page == 'menus' %}active{% endif %}">
                {{ trans('menu.main_course') }}
            </a>

            <a href="{{ base_path }}/calendar"
            class="{% if active_page is defined and active_page == 'calendar' %}active{% endif %}">
                {{ trans('admin.nav.calendar') }}
            </a>
        </nav>

        <form action="{{ base_path }}/auth/logout" method="POST" style="margin-top:auto;">
            <button type="submit" class="admin-logout-btn">
                {{ trans('admin.nav.logout') }}
            </button>
        </form>
    </aside>

    <main class="admin-content">
        <div class="admin-page-header">
            <h2>{{ trans('admin.page.title') }}</h2>
        </div>

        <div class="admin-controls">
            <form method="GET" action="{{ base_path }}/clients" style="display:flex;gap:0.5rem;flex:1;">
                <input type="text" name="search" class="admin-search"
                       placeholder="{{ trans('admin.controls.search_placeholder') }}"
                       value="{{ search }}">
                <button type="submit" class="admin-filter-btn">{{ trans('admin.controls.filter') }}</button>
                {% if search %}
                    <a href="{{ base_path }}/clients" class="admin-filter-btn" style="text-decoration:none;">✕</a>
                {% endif %}
            </form>
        </div>

        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>{{ trans('admin.table.client') }}</th>
                        <th>{{ trans('client.email') }}</th>
                        <th>{{ trans('admin.table.phone') }}</th>
                        <th>{{ trans('admin.table.details') }}</th>
                        <th>{{ trans('admin.table.delete') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for client in clients %}
                    <tr>
                        <td>{{ client.firstName }} {{ client.lastName }}</td>
                        <td>{{ client.email }}</td>
                        <td>{{ client.phoneNumber }}</td>
                        <td>
                            <a href="{{ base_path }}/clients/{{ client.clientId }}" class="admin-btn edit">
                                {{ trans('admin.actions.view_details') }}
                            </a>
                        </td>
                        <td>
                            <form action="{{ base_path }}/clients/{{ client.clientId }}/delete" method="POST" style="display:inline;"
                                  onsubmit="return confirm('{{ trans('admin.confirm.delete_client') }}');">
                                <button type="submit" class="admin-btn delete">
                                    {{ trans('admin.actions.delete_client') }}
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="no-results">{{ trans('admin.states.no_clients') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </main>
</div>

{% endblock %}
