{% extends 'layout.html.twig' %}

{% block title %}
    {{ 'site.name'|trans }}
{% endblock %}

{% block content %}
<section class="hero">

    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-grain"></div>

    <a href="tel:{{ 'site.phone_raw'|trans }}" class="top-phone">T &nbsp;{{ 'site.phone'|trans }}</a>

    <div class="hero-content">

        <h1 class="title">
            <span class="title-name">{{ 'site.name'|trans }}</span>
        </h1>
        <p class="subtitle" id="subtitle">{{ 'hero.subtitle'|trans }}</p>

        <div class="gold-divider">
            <div class="gold-divider-line rev"></div>
            <div class="gold-divider-dot"></div>
            <div class="gold-divider-line"></div>
        </div>

        <div class="btn-group">

            <a href="{{ base_path }}/client-form" class="btn-primary" id="btn-book">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
                <span id="book-label">{{ 'hero.book'|trans }}</span>
            </a>

            <a href="{{ base_path }}/admin" class="btn-outline" id="btn-admin">{{ 'hero.admin'|trans }}</a>

            <div class="btn-ghost-row">
                <a href="{{ base_path }}/faq" class="btn-ghost" id="btn-faq">{{ 'hero.faq'|trans }}</a>
                <a href="{{ base_path }}/reviews" class="btn-ghost" id="btn-reviews">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <polygon
                            points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                    <span id="reviews-label">{{ 'hero.reviews'|trans }}</span>
                </a>
            </div>

        </div>
    </div>

    <div class="bottom-bar">
        <div class="bottom-row">
            <a href="mailto:{{ 'site.email'|trans }}" class="bottom-contact">{{ 'site.email'|trans }}</a>
            <div class="bottom-lang">
                <a id="lang-en" class="active" onclick="setLang('en')">EN</a>
                <span class="sep">|</span>
                <a id="lang-fr" onclick="setLang('fr')">FR</a>
            </div>
        </div>
        <p class="bottom-rights" id="rights">{{ 'hero.rights'|trans }}</p>
    </div>

</section>

<script>
    const translations = {
        en: {
            subtitle: '{{ 'hero.subtitle.en'|trans|e('js') }}',
            book: '{{ 'hero.book.en'|trans|e('js') }}',
            admin: '{{ 'hero.admin.en'|trans|e('js') }}',
            faq: '{{ 'hero.faq'|trans|e('js') }}',
            reviews: '{{ 'hero.reviews.en'|trans|e('js') }}',
            discover: '{{ 'hero.discover.en'|trans|e('js') }}',
            rights: '{{ 'hero.rights.en'|trans|e('js') }}'
        },
        fr: {
            subtitle: '{{ 'hero.subtitle.fr'|trans|e('js') }}',
            book: '{{ 'hero.book.fr'|trans|e('js') }}',
            admin: '{{ 'hero.admin.fr'|trans|e('js') }}',
            faq: '{{ 'hero.faq'|trans|e('js') }}',
            reviews: '{{ 'hero.reviews.fr'|trans|e('js') }}',
            discover: '{{ 'hero.discover.fr'|trans|e('js') }}',
            rights: '{{ 'hero.rights.fr'|trans|e('js') }}'
        }
    };

    function setLang(lang) {
        const t = translations[lang];
        document.getElementById('subtitle').textContent = t.subtitle;
        document.getElementById('book-label').textContent = t.book;
        document.getElementById('btn-admin').textContent = t.admin;
        document.getElementById('btn-faq').textContent = t.faq;
        document.getElementById('reviews-label').textContent = t.reviews;
        document.getElementById('rights').textContent = t.rights;
        document.getElementById('lang-en').classList.toggle('active', lang === 'en');
        document.getElementById('lang-fr').classList.toggle('active', lang === 'fr');
        document.documentElement.lang = lang;
    }
</script>
{% endblock %}
