{% extends 'base.html.twig' %}

{% block title %}Book Your Event — Le Châteaubriand{% endblock %}

{% block navbar %}
<nav class="cb-navbar d-flex align-items-center justify-content-between">
    <a href="{{ path_home ?? (base_path|default('') ~ '/') }}" class="text-decoration-none text-muted d-flex align-items-center gap-1"
       style="font-size:0.9rem;">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <a href="{{ path_home ?? (base_path|default('') ~ '/') }}" class="navbar-brand">
        <i class="bi bi-building brand-icon"></i> Le Châteaubriand
    </a>
</nav>
{% endblock %}

{% block content %}
<div style="max-width:780px;margin:0 auto;padding:1rem;">

    {# Validation errors #}
    {% if errors is defined and errors|length > 0 %}
        <div class="alert alert-danger">
            <ul class="mb-0">
                {% for err in errors %}
                    <li>{{ err }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="cb-card p-4" style="border-radius:14px;">

        {# ── Personal Information ── #}
        <form method="POST" action="{{ booking_action ?? (base_path|default('') ~ '/booking') }}" novalidate>
            <input type="hidden" name="csrf_token" value="{{ csrf_token ?? '' }}">

            <h3 class="section-title mb-3">Personal Information</h3>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label for="first_name" class="form-label small fw-medium">First Name *</label>
                    <input type="text" class="form-control" id="first_name" name="first_name"
                           value="{{ form.first_name ?? '' }}" required>
                </div>
                <div class="col-md-6">
                    <label for="last_name" class="form-label small fw-medium">Last Name *</label>
                    <input type="text" class="form-control" id="last_name" name="last_name"
                           value="{{ form.last_name ?? '' }}" required>
                </div>
                <div class="col-md-6">
                    <label for="email" class="form-label small fw-medium">Email *</label>
                    <input type="email" class="form-control" id="email" name="email"
                           value="{{ form.email ?? '' }}" required>
                </div>
                <div class="col-md-6">
                    <label for="phone" class="form-label small fw-medium">Phone *</label>
                    <input type="tel" class="form-control" id="phone" name="phone"
                           value="{{ form.phone ?? '' }}" required>
                </div>
            </div>

            {# ── Event Details ── #}
            <h3 class="section-title mb-3">Event Details</h3>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label for="event_type" class="form-label small fw-medium">Event Type *</label>
                    <select class="form-select" id="event_type" name="event_type" required>
                        <option value="" disabled {% if not form.event_type is defined %}selected{% endif %}>
                            Select event type
                        </option>
                        {% for type in ['Wedding', 'Corporate Event', 'Birthday Party', 'Anniversary', 'Other'] %}
                            <option value="{{ type }}"
                                    {% if form.event_type is defined and form.event_type == type %}selected{% endif %}>
                                {{ type }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-6">
                    <label for="event_date" class="form-label small fw-medium">Event Date *</label>
                    <input type="date" class="form-control" id="event_date" name="event_date"
                           value="{{ form.event_date ?? '' }}" min="{{ "now"|date('Y-m-d') }}" required>
                </div>
                <div class="col-md-6">
                    <label for="duration" class="form-label small fw-medium">Duration (hours)</label>
                    <input type="number" class="form-control" id="duration" name="duration"
                           value="{{ form.duration ?? '' }}" min="1" max="24" placeholder="e.g. 5">
                </div>
                <div class="col-md-6">
                    <label for="guest_count" class="form-label small fw-medium">Number of Guests *</label>
                    <input type="number" class="form-control" id="guest_count" name="guest_count"
                           value="{{ form.guest_count ?? '' }}" min="1" required>
                </div>
            </div>

            {# ── Menu Selection ── #}
            <h3 class="section-title mb-2">Menu Selection *</h3>
            <div class="mb-4">
                {% set menu_options = [
                    { value: 'main_menu',     label: 'Main Menu Options' },
                    { value: 'buffet',        label: 'Buffet Menu' },
                    { value: 'midnight_table',label: 'Midnight Table' }
                ] %}
                {% for option in menu_options %}
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio"
                           name="menu_type" id="menu_{{ option.value }}"
                           value="{{ option.value }}"
                           {% if form.menu_type is defined and form.menu_type == option.value %}checked{% endif %}
                           required>
                    <label class="form-check-label text-teal fw-medium" for="menu_{{ option.value }}">
                        {{ option.label }}
                    </label>
                </div>
                {% endfor %}
            </div>

            {# ── Bar Service ── #}
            <h3 class="section-title mb-2">Bar Service</h3>
            <div class="mb-4">
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="bar_service"
                           name="bar_service" value="1"
                           {% if form.bar_service is defined and form.bar_service %}checked{% endif %}>
                    <label class="form-check-label" for="bar_service">Include bar service</label>
                </div>
                <div id="barTypeSection" class="{% if not (form.bar_service is defined and form.bar_service) %}d-none{% endif %} ps-2">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="bar_type" id="bar_free"
                               value="free" {% if form.bar_type == 'free' %}checked{% endif %}>
                        <label class="form-check-label" for="bar_free">Open bar (free)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="bar_type" id="bar_paid"
                               value="paid" {% if form.bar_type == 'paid' %}checked{% endif %}>
                        <label class="form-check-label" for="bar_paid">Bar (paid per drink)</label>
                    </div>
                </div>
            </div>

            {# ── Additional Notes ── #}
            <h3 class="section-title mb-2">Additional Notes</h3>
            <div class="mb-4">
                <textarea class="form-control" id="notes" name="notes"
                          rows="3"
                          placeholder="Special requests, dietary restrictions, etc.">{{ form.notes ?? '' }}</textarea>
            </div>

            {# Submit #}
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-cb-primary px-4 py-2">
                    Continue to Table Selection
                    <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </div>

        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    // Show/hide bar type when bar service toggled
    const barToggle = document.getElementById('bar_service');
    const barSection = document.getElementById('barTypeSection');
    barToggle.addEventListener('change', () => {
        barSection.classList.toggle('d-none', !barToggle.checked);
    });
</script>
{% endblock %}
