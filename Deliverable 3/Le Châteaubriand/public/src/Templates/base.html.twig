<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>{% block title %}Le Châteaubriand{% endblock %}</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

<style>
:root {
    --cb-teal: #2a9d8f;
    --cb-teal-dark: #21867a;
    --cb-bg: #f5f7f8;
    --cb-text: #1f2933;
}

body {
    margin:0;
    background: var(--cb-bg);
    font-family: system-ui, sans-serif;
    color: var(--cb-text);
}

/* 🔥 FORCE CENTERING SYSTEM */
.page-center {
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
}

/* 🔥 CONTAINERS */
.container-narrow {
    width:100%;
    max-width:900px;
    margin:auto;
}

/* 🔥 CARD */
.cb-card {
    background:white;
    border-radius:20px;
    padding:2.2rem;
    box-shadow:0 20px 60px rgba(0,0,0,0.08);
}

/* 🔥 BUTTONS */
.btn-cb-primary {
    background:var(--cb-teal);
    color:white;
    border:none;
    border-radius:14px;
    padding:0.8rem 1.2rem;
    font-weight:600;
}
.btn-cb-primary:hover {
    background:var(--cb-teal-dark);
}

.btn-cb-outline {
    border:2px solid var(--cb-teal);
    color:var(--cb-teal);
    border-radius:14px;
}

/* 🔥 REMOVE LINK LOOK */
a {
    text-decoration:none !important;
}

/* 🔥 FORM */
.form-control {
    border-radius:14px;
    padding:0.65rem;
}

/* 🔥 TYPOGRAPHY */
.section-title {
    font-weight:600;
    margin-bottom:1.5rem;
    font-size:1.3rem;
}
</style>
</head>

<body>

{% block navbar %}{% endblock %}

<main>
    {% block content %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>