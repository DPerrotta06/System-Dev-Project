{% extends 'layout.html.twig' %}

{% block title %}{{ trans('site.name') }}{% endblock %}

{% block content %}
<div class="client-form-container">

    <form action="/submit-form" method="post">

        <h3>{{ trans('form.personal_info') }}</h3>
        <input type="text" name="firstname" placeholder="{{ trans('form.firstname') }}" required>
        <input type="text" name="lastname" placeholder="{{ trans('form.lastname') }}" required>
        <input type="email" name="email" placeholder="{{ trans('form.email') }}" required>
        <input type="text" name="phone" placeholder="{{ trans('form.phone') }}" required>

        <h3>{{ trans('form.event_details') }}</h3>
        <select name="event_type" required>
            <option value="">{{ trans('form.select_event_type') }}</option>
            <option value="Wedding">{{ trans('form.wedding') }}</option>
            <option value="Corporate">{{ trans('form.corporate') }}</option>
            <option value="Birthday">{{ trans('form.birthday') }}</option>
            <option value="Anniversary">{{ trans('form.anniversary') }}</option>
            <option value="Baby Shower">{{ trans('form.baby_shower') }}</option>
            <option value="Other">{{ trans('form.other') }}</option>
        </select>

        <input type="date" name="event_date" required>
        <input type="number" name="number_of_guests" placeholder="{{ trans('form.number_of_guests') }}" required>

        <h3>{{ trans('form.menu_selection') }}</h3>
        <label>
            <input type="checkbox" class="menu-toggle" data-target="mainMenu">
            {{ trans('form.main_menu') }}
        </label>
        <label>
            <input type="checkbox" class="menu-toggle" data-target="buffetMenu">
            {{ trans('form.buffet') }}
        </label>
        <label>
            <input type="checkbox" class="menu-toggle" data-target="midnightMenu">
            {{ trans('form.midnight_table') }}
        </label>

        <div id="mainMenu" class="menu-section hidden">
            {% for key, items in menus.main %}
                <div class="menu-category">
                    <h4>{{ trans('menu.' ~ key) }}</h4>
                    {% for item in items %}
                        <label>
                            <input type="checkbox" name="main_{{ key }}[]" value="{{ item }}">
                            {{ item }}
                        </label>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>

        <div id="buffetMenu" class="menu-section hidden">
            {% for key, items in menus.buffet %}
                <div class="menu-category">
                    <h4>{{ trans('menu.' ~ key) }}</h4>
                    {% for item in items %}
                        <label>
                            <input type="checkbox" name="buffet_{{ key }}[]" value="{{ item }}">
                            {{ item }}
                        </label>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>

        <div id="midnightMenu" class="menu-section hidden">
            {% for key, items in menus.midnight %}
                <div class="menu-category">
                    <h4>{{ trans('menu.' ~ key) }}</h4>
                    {% for item in items %}
                        <label>
                            <input type="checkbox" name="midnight_{{ key }}[]" value="{{ item }}">
                            {{ item }}
                        </label>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>

        <h3>{{ trans('form.additional_notes') }}</h3>
        <textarea name="notes" placeholder="{{ trans('form.notes_placeholder') }}"></textarea>
        <br><br>

        <button type="submit">{{ trans('form.continue_floor') }}</button>

    </form>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const toggles = document.querySelectorAll(".menu-toggle");
    toggles.forEach(toggle => {
        toggle.addEventListener("change", function () {
            const target = document.getElementById(this.dataset.target);
            target.classList.toggle("hidden", !this.checked);
        });
    });
});
</script>
{% endblock %}