{% extends 'layout.html.twig' %}
{% block title %}{{ 'site.name'|trans }}{% endblock %}
{% block content %}
<div class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1>{{ 'site.name'|trans }}</h1>
        <p>{{ 'hero.subtitle'|trans }}</p>
        <div class="hero-buttons">
            <a href="/client-form" class="btn-primary">
                {{ 'hero.book'|trans }}
            </a>
            <a href="/faq" class="btn-secondary">
                {{ 'hero.faq'|trans }}
            </a>
            <a href="/reviews" class="btn-secondary">
                {{ 'hero.reviews'|trans }}
            </a>
            <a href="/admin" class="btn-secondary">
                {{ 'hero.admin'|trans }}
            </a>
        </div>
        <div class="hero-footer">
            <p>{{ 'site.phone'|trans }}</p>
            <p>{{ 'site.email'|trans }}</p>
            <p>{{ 'hero.rights'|trans }}</p>
        </div>
    </div>
</div>
{% endblock %}