{% extends 'base.html.twig' %}

{% block content %}
<div class="page-center">

    <div class="cb-card text-center" style="max-width:420px;">

        <h1 class="fw-bold">Le Châteaubriand</h1>
        <p class="text-muted mb-4">Centre de Congrès et Réceptions</p>

        <a href="{{ path_book ?? (base_path ~ '/booking') }}"
           class="btn btn-cb-primary w-100 mb-3">
            Book Your Event
        </a>

        <div class="d-flex justify-content-center gap-2 mb-3">
            <a href="{{ path_faq ?? (base_path ~ '/faq') }}">FAQ</a>
            <a href="{{ path_reviews ?? (base_path ~ '/review') }}">Reviews</a>
        </div>

        <a href="{{ path_admin_login ?? (base_path ~ '/auth') }}"
           class="btn btn-cb-outline">
            Admin Login
        </a>

    </div>
</div>
{% endblock %}
