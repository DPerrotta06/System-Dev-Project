{% extends 'base.html.twig' %}

{% block title %}Client Details{% endblock %}

{% block navbar %}
    {% include 'admin/_admin_navbar.html.twig' %}
{% endblock %}

{% block content %}
<div class="container">

    <div class="cb-card">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="section-title mb-0">
                {{ client.first_name }} {{ client.last_name }}
            </h2>

            <a href="{{ path_edit_client ?? (base_path|default('') ~ '/clients') }}/{{ client.id }}/edit"
               class="btn btn-cb-primary">
                Edit
            </a>
        </div>

        <div class="row g-4">

            <div class="col-md-6">
                <p><strong>Email:</strong> {{ client.email }}</p>
                <p><strong>Phone:</strong> {{ client.phone }}</p>
                <p><strong>Date:</strong> {{ client.event_date }}</p>
                <p><strong>Type:</strong> {{ client.event_type }}</p>
                <p><strong>Guests:</strong> {{ client.guest_count }}</p>
                <p><strong>Budget:</strong> ${{ client.budget }}</p>
            </div>

            <div class="col-md-6">
                <p><strong>Ballroom:</strong> {{ client.ballroom }}</p>

                {% if client.services %}
                    <p><strong>Services:</strong></p>
                    <div class="d-flex flex-wrap gap-2">
                        {% for s in client.services %}
                            <span class="badge bg-light text-dark">{{ s }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

        </div>

    </div>
</div>
{% endblock %}