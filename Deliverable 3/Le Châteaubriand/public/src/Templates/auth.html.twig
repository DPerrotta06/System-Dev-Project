{% extends 'layout.html.twig' %}
{% block title %}{{ trans('auth.title') }} - {{ trans('site.name') }}{% endblock %}
{% block content %}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h2>{{ trans('site.name') }}</h2>
            <p>{{ trans('auth.title') }}</p>
        </div>

        <form method="POST" action="/login" class="auth-form">

            {% if error is defined %}
                <div class="auth-error">
                    {{ trans(error) }}
                </div>
            {% endif %}

            <div class="form-group">
                <label for="email">{{ trans('auth.email') }}</label>
                <input 
                    type="email" 
                    id="email"
                    name="email" 
                    required 
                    placeholder="{{ trans('auth.email_placeholder') }}"
                >
            </div>

            <div class="form-group">
                <label for="password">{{ trans('auth.password') }}</label>
                <input type="password" id="password" name="password" required placeholder="{{ trans('auth.password_placeholder') }}">
            </div>

            <button type="submit" class="btn-primary">
                {{ trans('auth.login') }}
            </button>
        </form>
    </div>
</div>
{% endblock %}