{# copied from login.html.twig to match controller render path 'auth.html.twig' #}
{% extends 'base.html.twig' %}

{% block title %}Admin Login — Le Châteaubriand{% endblock %}

{% block content %}
<div class="d-flex align-items-center justify-content-center" style="min-height:80vh;background:#f6f7f7;">
    <div style="width:100%;max-width:420px;padding:1rem;">
        <div class="cb-card p-4 text-center">
            <i class="bi bi-building" style="font-size:2.2rem;color:var(--cb-teal);"></i>
            <h2 class="fw-bold mt-2 mb-0" style="font-size:1.35rem;">Le Châteaubriand</h2>
            <p class="text-muted mb-4" style="font-size:0.82rem;">Admin Login</p>

            {% if error is defined and error %}
                <div class="alert alert-danger py-2 text-start d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    <span>{{ error }}</span>
                </div>
            {% endif %}

            <form method="POST" action="{{ path_login ?? (base_path|default('') ~ '/auth/request') }}" novalidate>
                <input type="hidden" name="csrf_token" value="{{ csrf_token ?? '' }}">
                <div class="mb-3 text-start">
                    <label for="email" class="form-label small fw-medium">Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-envelope text-muted"></i>
                        </span>
                        <input type="email" id="email" name="email" class="form-control border-start-0 ps-0" placeholder="admin@lechateaubriand.com" required>
                    </div>
                </div>

                <div class="mb-4 text-start">
                    <label for="password" class="form-label small fw-medium">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-lock text-muted"></i>
                        </span>
                        <input type="password" id="password" name="password" class="form-control border-start-0 ps-0" placeholder="••••••••" required>
                        <button type="button" class="btn btn-outline-secondary border-start-0" id="togglePassword" style="border-color:#ced4da;">
                            <i class="bi bi-eye" id="toggleIcon"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn btn-cb-primary w-100 py-2">Sign in</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
