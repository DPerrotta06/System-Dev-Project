{% extends "layout.html.twig" %}

{% block title %}{{ trans('reviews.page_title') }} - {{ trans('site.name') }}{% endblock %}

{% block content %}
<section class="reviews-hero">
    <div class="container">
        <h1>{{ trans('reviews.page_title') }}</h1>
        <p class="subtitle">{{ trans('reviews.page_subtitle') }}</p>
        
        <!-- Google Reviews Badge -->
        <div class="google-reviews-badge" id="google-reviews-badge">
            <div class="google-logo">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
            </div>
            <div class="reviews-info">
                <div class="rating" id="google-rating">
                    <span class="stars" id="stars">★★★★★</span>
                    <span class="rating-count" id="rating-count">4.9</span>
                </div>
                <div class="review-count" id="review-count">Based on 200+ Google reviews</div>
            </div>
            <a href="https://www.google.com/maps/place/Le+Ch%C3%A2teaubriand/@45.6314022,-73.5903179,16z/data=!4m8!3m7!1s0x4cc91fd4223ded11:0xe2e8ef3ed5f38415!8m2!3d45.6314022!4d-73.5903179!9m1!1b1!16s%2Fg%2F1thx3nq_?authuser=0&entry=ttu&g_ep=EgoyMDI2MDQyOC4wIKXMDSoASAFQAw%3D%3D" 
               class="btn-primary" target="_blank" rel="noopener">
                {{ trans('reviews.view_all_google') }}
            </a>
        </div>
    </div>
</section>

<section class="reviews-content">
    <div class="container">
        <!-- Loading State -->
        <div class="loading" id="loading-reviews">
            <div class="spinner"></div>
            <p>{{ trans('reviews.loading') }}</p>
        </div>

        <!-- Reviews Grid -->
        <div class="reviews-grid" id="reviews-grid" style="display: none;">
            <!-- Reviews will be loaded dynamically -->
        </div>

        <!-- Error State -->
        <div class="error-message" id="error-message" style="display: none;">
            <p>{{ trans('reviews.error_loading') }}</p>
            <button class="btn-outline" onclick="loadGoogleReviews()">{{ trans('reviews.retry') }}</button>
        </div>

        <!-- Fallback Reviews (shown if API fails) -->
        <div class="fallback-reviews" id="fallback-reviews">
            <div class="review-card">
                <div class="review-header">
                    <div class="reviewer-info">
                        <div class="reviewer-name">Sarah M.</div>
                        <div class="review-date">{{ trans('reviews.months_ago', {'%count%': 2}) }}</div>
                    </div>
                    <div class="review-rating">★★★★★</div>
                </div>
                <p class="review-text">"Absolutely stunning venue! The staff was incredibly professional and the food was exceptional. Our wedding was a dream come true thanks to the team at Le Châteaubriand."</p>
            </div>

            <div class="review-card">
                <div class="review-header">
                    <div class="reviewer-info">
                        <div class="reviewer-name">Michael T.</div>
                        <div class="review-date">{{ trans('reviews.months_ago', {'%count%': 3}) }}</div>
                    </div>
                    <div class="review-rating">★★★★★</div>
                </div>
                <p class="review-text">"Hosted our corporate event here and it exceeded all expectations. The attention to detail and customer service was outstanding. Highly recommend!"</p>
            </div>

            <div class="review-card">
                <div class="review-header">
                    <div class="reviewer-info">
                        <div class="reviewer-name">Jennifer L.</div>
                        <div class="review-date">{{ trans('reviews.months_ago', {'%count%': 1}) }}</div>
                    </div>
                    <div class="review-rating">★★★★★</div>
                </div>
                <p class="review-text">"The most beautiful venue in the area! Our guests are still talking about how amazing everything was. The coordinator helped us with every detail."</p>
            </div>
        </div>

        <!-- Direct Link Section -->
        <div class="google-link-section">
            <h2>{{ trans('reviews.more_on_google') }}</h2>
            <p>{{ trans('reviews.more_on_google_desc') }}</p>
            <a href="https://www.google.com/maps/place/Le+Ch%C3%A2teaubriand/@45.6314022,-73.5903179,16z/data=!4m8!3m7!1s0x4cc91fd4223ded11:0xe2e8ef3ed5f38415!8m2!3d45.6314022!4d-73.5903179!9m1!1b1!16s%2Fg%2F1thx3nq_?authuser=0&entry=ttu&g_ep=EgoyMDI2MDQyOC4wIKXMDSoASAFQAw%3D%3D" 
               class="btn-primary" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" width="20" height="20" style="margin-right: 8px;">
                    <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                {{ trans('reviews.view_all_google') }}
            </a>
        </div>
    </div>
</section>

<style>
.reviews-hero {
    text-align: center;
    padding: 4rem 0 2rem;
    background: linear-gradient(135deg, #0a0906 0%, #1a1a1a 100%);
}

.reviews-hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    color: #C9A84C;
    margin-bottom: 1rem;
}

.subtitle {
    font-size: 1.1rem;
    color: rgba(245, 240, 232, 0.8);
    margin-bottom: 2rem;
}

.google-reviews-badge {
    background: rgba(201, 168, 76, 0.1);
    border: 1px solid rgba(201, 168, 76, 0.3);
    border-radius: 12px;
    padding: 2rem;
    max-width: 500px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
}

.google-logo svg {
    width: 48px;
    height: 48px;
}

.reviews-info {
    text-align: center;
}

.rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
}

.stars {
    color: #FBBC05;
    font-size: 1.5rem;
    letter-spacing: 2px;
}

.rating-count {
    font-size: 1.5rem;
    font-weight: bold;
    color: #C9A84C;
}

.review-count {
    color: rgba(245, 240, 232, 0.6);
    font-size: 0.9rem;
}

.reviews-content {
    padding: 3rem 0;
}

.loading {
    text-align: center;
    padding: 3rem;
}

.spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(201, 168, 76, 0.3);
    border-top-color: #C9A84C;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto 1rem;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
}

.review-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(201, 168, 76, 0.2);
    border-radius: 12px;
    padding: 1.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.review-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(201, 168, 76, 0.15);
}

.review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
}

.reviewer-info {
    flex: 1;
}

.reviewer-name {
    font-weight: 600;
    color: #C9A84C;
    margin-bottom: 0.25rem;
}

.review-date {
    font-size: 0.85rem;
    color: rgba(245, 240, 232, 0.5);
}

.review-rating {
    color: #FBBC05;
    font-size: 0.9rem;
    letter-spacing: 1px;
}

.review-text {
    color: rgba(245, 240, 232, 0.8);
    line-height: 1.6;
    font-style: italic;
}

.error-message {
    text-align: center;
    padding: 2rem;
    color: #EA4335;
}

.fallback-reviews {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
}

.google-link-section {
    text-align: center;
    padding: 3rem 0;
    border-top: 1px solid rgba(201, 168, 76, 0.2);
}

.google-link-section h2 {
    font-family: 'Playfair Display', serif;
    color: #C9A84C;
    margin-bottom: 1rem;
}

.google-link-section p {
    color: rgba(245, 240, 232, 0.7);
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

@media (max-width: 768px) {
    .reviews-grid,
    .fallback-reviews {
        grid-template-columns: 1fr;
    }
    
    .reviews-hero h1 {
        font-size: 2rem;
    }
}
</style>

<script>
// Google Places API Configuration
const GOOGLE_PLACE_ID = 'ChIJEe09ItQfyUwRFeT13j7v6OI'; // Extracted from your URL
const GOOGLE_MAPS_URL = 'https://www.google.com/maps/place/Le+Ch%C3%A2teaubriand/@45.6314022,-73.5903179,16z/data=!4m8!3m7!1s0x4cc91fd4223ded11:0xe2e8ef3ed5f38415!8m2!3d45.6314022!4d-73.5903179!9m1!1b1!16s%2Fg%2F1thx3nq_?authuser=0&entry=ttu&g_ep=EgoyMDI2MDQyOC4wIKXMDSoASAFQAw%3D%3D';

// Load Google Reviews
async function loadGoogleReviews() {
    const loadingEl = document.getElementById('loading-reviews');
    const gridEl = document.getElementById('reviews-grid');
    const errorEl = document.getElementById('error-message');
    const fallbackEl = document.getElementById('fallback-reviews');
    
    try {
        // Show loading
        loadingEl.style.display = 'block';
        gridEl.style.display = 'none';
        errorEl.style.display = 'none';
        fallbackEl.style.display = 'none';
        
        // Fetch reviews using Google Places API
        const response = await fetch(`/api/google-reviews?place_id=${GOOGLE_PLACE_ID}`);
        
        if (!response.ok) {
            throw new Error('Failed to load reviews');
        }
        
        const data = await response.json();
        
        if (data.status === 'OK' && data.result) {
            // Update rating badge
            const rating = data.result.rating || 4.9;
            const userRatingsTotal = data.result.user_ratings_total || 200;
            
            document.getElementById('rating-count').textContent = rating.toFixed(1);
            document.getElementById('review-count').textContent = 
                `Based on ${userRatingsTotal}+ Google reviews`;
            
            // Display reviews
            displayReviews(data.result.reviews || []);
            
            loadingEl.style.display = 'none';
            gridEl.style.display = 'grid';
        } else {
            throw new Error('No reviews found');
        }
    } catch (error) {
        console.error('Error loading Google reviews:', error);
        loadingEl.style.display = 'none';
        errorEl.style.display = 'block';
        fallbackEl.style.display = 'grid';
    }
}

function displayReviews(reviews) {
    const gridEl = document.getElementById('reviews-grid');
    gridEl.innerHTML = '';
    
    // Show top 6 reviews
    const topReviews = reviews.slice(0, 6);
    
    topReviews.forEach(review => {
        const card = document.createElement('div');
        card.className = 'review-card';
        
        const date = new Date(review.time * 1000);
        const monthsAgo = Math.floor((Date.now() - date.getTime()) / (30 * 24 * 60 * 60 * 1000));
        
        card.innerHTML = `
            <div class="review-header">
                <div class="reviewer-info">
                    <div class="reviewer-name">${escapeHtml(review.author_name)}</div>
                    <div class="review-date">${getMonthsAgoText(monthsAgo)}</div>
                </div>
                <div class="review-rating">${'★'.repeat(review.rating)}${'☆'.repeat(5 - review.rating)}</div>
            </div>
            <p class="review-text">"${escapeHtml(review.text)}"</p>
        `;
        
        gridEl.appendChild(card);
    });
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function getMonthsAgoText(months) {
    if (months === 0) return '{{ trans("reviews.this_month") }}';
    if (months === 1) return '{{ trans("reviews.month_ago") }}';
    return `{{ trans("reviews.months_ago") }}`.replace('%count%', months);
}

// Load reviews when page loads
document.addEventListener('DOMContentLoaded', loadGoogleReviews);
</script>
{% endblock %}