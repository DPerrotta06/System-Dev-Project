{% extends "layout.html.twig" %}

{% block title %}{{ trans('reviews.page_title') }} - {{ trans('site.name') }}{% endblock %}

{% block content %}
<section class="reviews-hero">
    <div class="container">
        <h1>{{ trans('reviews.page_title') }}</h1>
        <p class="subtitle">{{ trans('reviews.page_subtitle') }}</p>
        
        <div class="google-reviews-badge">
            <div class="google-logo">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
            </div>
            <div class="reviews-info">
                <div class="rating">
                    <span class="stars">★★★★★</span>
                    <span class="rating-count">4.5</span>
                </div>
                <div class="review-count">Based on 482 Google reviews</div>
            </div>
            <a href="https://www.google.com/maps/place/Le+Ch%C3%A2teaubriand/@45.6314022,-73.5903179,16z/data=!4m8!3m7!1s0x4cc91fd4223ded11:0xe2e8ef3ed5f38415!8m2!3d45.6314022!4d-73.5903179!9m1!1b1!16s%2Fg%2F1thx3nq_?authuser=0&entry=ttu&g_ep=EgoyMDI2MDQyOC4wIKXMDSoASAFQAw%3D%3D" 
               class="btn-primary" target="_blank" rel="noopener">
                {{ trans('reviews.view_all_google') }}
            </a>
        </div>
    </div>
</section>

<section class="reviews-content">
    <div class="container">
        <!-- Elfsight Google Reviews Widget -->
        <script src="https://elfsightcdn.com/platform.js" async></script>
        <div class="elfsight-app-f0623966-e1e1-4cc7-8077-3a7cac510999" data-elfsight-app-lazy></div>

        <!-- Direct Link Section -->
        <div class="google-link-section">
            <h2>{{ trans('reviews.more_on_google') }}</h2>
            <p>{{ trans('reviews.more_on_google_desc') }}</p>
            <a href="https://www.google.com/maps/place/Le+Ch%C3%A2teaubriand/@45.6314022,-73.5903179,16z/data=!4m8!3m7!1s0x4cc91fd4223ded11:0xe2e8ef3ed5f38415!8m2!3d45.6314022!4d-73.5903179!9m1!1b1!16s%2Fg%2F1thx3nq_?authuser=0&entry=ttu&g_ep=EgoyMDI2MDQyOC4wIKXMDSoASAFQAw%3D%3D" 
               class="btn-primary" target="_blank" rel="noopener">
                {{ trans('reviews.view_all_google') }}
            </a>
        </div>
    </div>
</section>
{% endblock %}